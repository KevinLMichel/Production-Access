---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import FormatLinks from "../../../components/FormatLinks.astro";
import { getBooks } from "../../../lib/books";
import {
  chapterHref,
  getBookChapters,
  getChapterWordCount,
  groupChaptersByPart,
  readingTimeFromWords
} from "../../../lib/bookWorld";

const books = await getBooks();
const book = books.find((entry) => entry.id === "tao-of-maat");

if (!book) {
  throw new Error("The Tao of Ma’at catalogue record not found.");
}

const meditations = await getBookChapters("tao-of-maat");
const movements = groupChaptersByPart(meditations);
const firstMeditation = meditations[0];
const totalWords = meditations.reduce((sum, meditation) => sum + getChapterWordCount(meditation), 0);

const symbols = [
  {
    name: "The feather",
    line: "Lightness of heart: the daily test of whether speech, appetite, and action have grown too heavy."
  },
  {
    name: "The scales",
    line: "Justice as balance: not passive calm, but the discipline of giving each thing its right weight."
  },
  {
    name: "The sun",
    line: "Illumination without noise: the quiet power of truth when it no longer needs to shout."
  },
  {
    name: "The path",
    line: "The way made visible through conduct: humility, restraint, right speech, and useful service."
  }
];

const practices = [
  "Read one meditation before speaking into conflict",
  "Choose one sentence to carry through the day",
  "Weigh pride before answering",
  "Let silence become a form of order",
  "Return to the scales when the heart grows loud"
];

const movementDescriptions = new Map([
  ["Cosmic Order", "The opening meditations establish balance, speech, truth, patience, justice, and pride."],
  ["Right Relations", "Friendship, ancestors, mercy, judgment, moderation, and the ethics of living among others."],
  ["Household and Heart", "Family, work, desire, age, memory, and the private places where order is first tested."],
  ["World as Teacher", "Rivers, dust, bread, harvest, silence, and the visible world as instruction."],
  ["Restraint and Courage", "Fear, anger, strength, gentleness, courage, forgiveness, and the discipline of measured force."],
  ["Social Conduct", "Leadership, wealth, service, reputation, law, gratitude, and public behavior."],
  ["Inner Virtue", "Conscience, prayer, solitude, acceptance, excellence, discipline, and the inner architecture of character."],
  ["Living Example", "Plain example, appearances, counsel, understanding, and the conduct that teaches without announcement."],
  ["The Final Weighing", "The scales, Ma’at, and the sage: the closing return to balance as lived wisdom."]
]);

function meditationLabel(meditation: typeof meditations[number]) {
  return `Meditation ${(meditation.data.subtitle ?? String(meditation.data.order)).replace(/\.$/, "")}`;
}
---

<BaseLayout
  title="The Tao of Ma’at | Production Access"
  description={book.data.description}
  bodyClass="theme-tao-of-maat"
>
  <section class="book-world-hero tao-hero" aria-labelledby="tao-title">
    <div class="book-world-hero__copy">
      <p class="eyebrow">The Tao of Ma’at</p>
      <h1 id="tao-title">Balance is not an idea. It is a way of walking.</h1>
      <p class="book-world-hero__subtitle">{book.data.dek}</p>
      <p class="book-world-hero__lede">
        Eighty-one short meditations on the weight of the heart, the discipline of speech,
        the humility that keeps power clean, and the old human work of bringing the inner life
        back into order.
      </p>
      <div class="hero__actions">
        {firstMeditation && <a class="button button--primary" href={chapterHref(firstMeditation)}>Start reading</a>}
        <a class="button button--ghost" href="#meditation-map">Explore meditations</a>
        <a class="text-link" href="/books/">Return to Library</a>
      </div>
      <FormatLinks formats={book.data.formats} />
    </div>

    <aside class="book-world-cover tao-cover" aria-label="The Tao of Ma’at cover">
      <img src={book.data.cover} alt="The Tao of Ma’at cover by Kevin L. Michel" />
    </aside>
  </section>

  <section class="freedom-stats tao-stats" aria-label="Book statistics">
    <div>
      <strong>{meditations.length}</strong>
      <span>meditations</span>
    </div>
    <div>
      <strong>{movements.length}</strong>
      <span>movements</span>
    </div>
    <div>
      <strong>{readingTimeFromWords(totalWords)}</strong>
      <span>minute read</span>
    </div>
  </section>

  <section class="freedom-section tao-section tao-promise">
    <p class="eyebrow">The book promise</p>
    <h2>To live by Ma’at is to make the heart lighter without making it smaller.</h2>
    <p>
      These meditations are not arguments to win. They are small rooms to enter: a scale, a feather,
      a doorway, a lamp. Read them quickly and they remain sentences. Read them slowly and they begin
      to ask what your speech serves, what your silence protects, and what order your life is teaching.
    </p>
  </section>

  <section class="freedom-section tao-section" aria-labelledby="symbols-heading">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Symbols</p>
        <h2 id="symbols-heading">Four images that hold the way</h2>
      </div>
    </div>
    <div class="outcome-grid tao-symbol-grid">
      {
        symbols.map((symbol) => (
          <article>
            <span>{symbol.name}</span>
            <p>{symbol.line}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="freedom-section tao-section" aria-labelledby="practice-heading">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Reading practice</p>
        <h2 id="practice-heading">How to use the meditations</h2>
      </div>
    </div>
    <div class="practice-grid tao-practice-grid">
      {
        practices.map((practice, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{practice}</h3>
            <p>
              The point is not to consume the whole sequence at once. The point is to let one
              meditation become a quiet correction in the ordinary weather of the day.
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="freedom-section tao-section" id="meditation-map" aria-labelledby="meditation-map-heading">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Movement map</p>
        <h2 id="meditation-map-heading">Eighty-one ways to return to balance</h2>
      </div>
    </div>

    <div class="part-map">
      {
        movements.map(({ part, chapters }) => (
          <section class="part-panel tao-part-panel" aria-labelledby={`movement-${chapters[0].data.order}`}>
            <p class="part-panel__label">{part}</p>
            <h3 id={`movement-${chapters[0].data.order}`}>{part}</h3>
            <p>{movementDescriptions.get(part)}</p>
            <div class="chapter-grid tao-meditation-grid">
              {chapters.map((meditation) => (
                <a class="chapter-tile tao-chapter-tile" href={chapterHref(meditation)}>
                  <span>{meditationLabel(meditation)}</span>
                  <strong>{meditation.data.title}</strong>
                  <small>{meditation.data.summary}</small>
                </a>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </section>
</BaseLayout>
