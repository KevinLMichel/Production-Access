---
import { createMarkdownProcessor } from "@astrojs/markdown-remark";
import PrintBookChapter from "../../../../components/PrintBookChapter.astro";
import { getBookChapters } from "../../../../lib/bookWorld";

const book = {
  title: "The Clock with No Hands",
  author: "Kevin L. Michel"
};

const aboutAuthor =
  "Kevin L. Michel writes philosophical fiction, practical philosophy, poetic allegory, civic reflection, and self-development works for readers trying to live with more clarity, courage, discipline, imagination, and inner authority. His books move between symbolic worlds, practical strategy, mythic reflection, and the everyday work of becoming more fully human.";

// Static folios keep the TOC aligned with visible printed page numbers without
// creating PDF annotations. The unnumbered part openers still count in foliation.
const tocPageNumbers: Record<number, number> = {
  0: 2,
  1: 8,
  2: 12,
  3: 17,
  4: 22,
  5: 27,
  6: 31,
  7: 37,
  8: 41,
  9: 45,
  10: 49,
  11: 53,
  12: 58,
  13: 62,
  14: 67,
  15: 71,
  16: 76,
  17: 80,
  18: 85,
  19: 90,
  20: 94,
  21: 98,
  22: 103,
  23: 107,
  24: 111,
  25: 116,
  26: 119,
  27: 124,
  28: 128,
  29: 133
};

const sections = await getBookChapters("clock-with-no-hands");
const markdownProcessor = await createMarkdownProcessor({ syntaxHighlight: false });

const renderedSections = await Promise.all(
  sections.map(async (section) => {
    const rendered = await markdownProcessor.render(section.body ?? "");
    return {
      section,
      html: rendered.code.replaceAll('src="/images/', 'src="images/'),
      printId: sectionId(section.data.order),
      label: section.data.subtitle ?? `Chapter ${section.data.order + 1}`
    };
  })
);

const printSections = [];
const seenParts = new Set<string>();

for (const entry of renderedSections) {
  const part = entry.section.data.part;

  if (!seenParts.has(part)) {
    seenParts.add(part);
    printSections.push({ type: "part", part, id: partId(part) });
  }

  printSections.push({ type: "section", ...entry });
}

function sectionId(order: number) {
  return `chapter-${order + 1}`;
}

function tocPageNumber(order: number) {
  return tocPageNumbers[order] ?? "";
}

function partId(part: string) {
  return part
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");
}

function partTitle(part: string) {
  return part.replace(/^Part\s+[IVX]+\s+-\s*/, "").trim();
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="author" content={book.author} />
    <meta name="description" content={`Print/PDF edition of ${book.title} by ${book.author}.`} />
    <title>{book.title} | PDF Edition</title>
  </head>
  <body>
    <section class="half-title-page" aria-label="Half title">
      <h1>{book.title}</h1>
    </section>

    <section class="title-page" aria-label="Title page">
      <div>
        <p class="title-eyebrow">A metaphysical novella</p>
        <h1>{book.title}</h1>
        <p class="title-author">{book.author}</p>
      </div>
    </section>

    <section class="copyright-page" aria-label="Copyright page">
      <p><strong>{book.title}</strong></p>
      <p>Copyright &copy; 2026 Kevin L. Michel.</p>
      <p>All rights reserved.</p>
      <p>
        No part of this publication may be reproduced, distributed, transmitted, stored in a retrieval system, or used in any form or by any means, electronic, mechanical, photocopying, recording, or otherwise, without prior written permission from the copyright owner, except as permitted by law.
      </p>
      <p>
        This is a work of literary fiction and philosophical allegory. Names, characters, places, incidents, systems, and symbolic settings are used imaginatively for narrative, artistic, and critical purposes.
      </p>
      <p>Printed in the United States of America.</p>
    </section>

    <nav class="toc-page" aria-label="Table of contents">
      <h1>Contents</h1>
      <ol>
        {
          printSections.map((section) =>
            section.type === "part" ? (
              <li class="toc-part-row">
                <div class="toc-part">
                  <span>{section.part}</span>
                </div>
              </li>
            ) : (
              <li>
                <div class="toc-entry" data-target={`#${section.printId}`} data-page={tocPageNumber(section.section.data.order)}>
                  <span class="toc-chapter">{section.label}</span>
                  <span class="toc-title">{section.section.data.title}</span>
                </div>
              </li>
            )
          )
        }
      </ol>
    </nav>

    <main class="book-body">
      {
        printSections.map((section) =>
          section.type === "part" ? (
            <section class="part-opener" id={section.id}>
              <p class="chapter-kicker">{section.part}</p>
              <h1>{partTitle(section.part)}</h1>
            </section>
          ) : (
            <PrintBookChapter
              chapter={section.section}
              printId={section.printId}
              html={section.html}
              kickerLabel={section.label}
              showSubtitle={false}
            />
          )
        )
      }
    </main>

    <section class="about-author-page" aria-label="About the Author">
      <h1>About the Author</h1>
      <p>{aboutAuthor}</p>
    </section>
  </body>
</html>
