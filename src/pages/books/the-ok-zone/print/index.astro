  { term: "Rut Zone", targets: ["idx-rut-zone"] },
  { term: "standards", targets: ["idx-success-definition", "idx-minimum-standard", "idx-performance-system"] },
  { term: "success", targets: ["idx-success-definition"] },
  { term: "tolerable discomfort", targets: ["idx-tolerable-discomfort", "idx-quiet-cost"] },
  { term: "Weekly Winning Zone Review", targets: ["idx-weekly-review"] },
  { term: "Winning Zone", targets: ["idx-winning-zone", "idx-weekly-review"] },
  { term: "zone map", targets: ["idx-zone-map"] }
