const book = {
  title: "The OK Zone",
  subtitle: "Why Comfortable Keeps You Stuck, and How to Build a Life You're Proud Of",
  author: "Tomas Svitorka"
};

const aboutAuthor =
  "Tomas Svitorka is a life and performance coach, speaker, and founder of the OK is NOT enough philosophy. With a background in psychology and more than a decade of coaching experience, he helps ambitious professionals, entrepreneurs, and high performers move beyond comfortable mediocrity and build lives they are genuinely proud of. His work combines practical psychology, clear strategy, accountability, and a no-BS approach to personal growth. Known for his direct, grounded style, Tomas challenges people to raise their standards, strengthen their confidence, and take consistent action toward the goals that matter most to them.";

