// Vivliostyle resolves backward index target-counters reliably, but forward
// TOC target-counters collapse under the page reset. These static locators
// mirror the visible printed folios for the current OK Zone print layout.
const tocPageNumbers: Record<number, number> = {
  0: 1,
  1: 9,
  2: 16,
  3: 23,
  4: 30,
  5: 38,
  6: 45,
  7: 52,
  8: 59,
  9: 67,
  10: 73,
  11: 80,
  12: 87,
  13: 94,
  14: 101,
  15: 109,
  16: 116,
  17: 122
};

const sections = await getBookChapters("the-ok-zone");
const markdownProcessor = await createMarkdownProcessor({ syntaxHighlight: false });

const renderedSections = await Promise.all(
  sections.map(async (section) => {
    const html = await renderPrintMarkdownWithIndexAnchors(section.body ?? "", section.data.order);

    return {
      section,
      html,
      printId: sectionId(section.data.order),
      label: section.data.subtitle ?? `Chapter ${section.data.order}`
    };
  })
);

const printIds = new Set(renderedSections.map((entry) => entry.printId));
const indexAnchorIds = new Set(indexAnchors.map((anchor) => anchor.id));
const undefinedTargets = [...collectIndexTargets(indexEntries)].filter(
  (target) => !printIds.has(target) && !indexAnchorIds.has(target)
);

if (undefinedTargets.length > 0) {
  throw new Error(`The OK Zone index has undefined targets: ${undefinedTargets.join(", ")}`);
}

async function renderPrintMarkdownWithIndexAnchors(markdown: string, order: number) {
  const injectedMarkdown = injectIndexAnchors(markdown, order);
  const rendered = await markdownProcessor.render(injectedMarkdown);
  return rendered.code.replaceAll('src="/images/', 'src="images/');
}

function injectIndexAnchors(markdown: string, order: number) {
  const normalizedMarkdown = markdown.replace(/\r\n/g, "\n");
  const anchors = indexAnchors.filter((anchor) => anchor.order === order);

  if (anchors.length === 0) {
    return normalizedMarkdown;
  }

  const insertions = new Map<number, string[]>();

  for (const anchor of anchors) {
    const phraseIndex = normalizedMarkdown.indexOf(anchor.phrase);

    if (phraseIndex === -1) {
      throw new Error(`The OK Zone index anchor phrase not found for ${anchor.id}: ${anchor.phrase}`);
    }

    const paragraphBreakIndex = normalizedMarkdown.lastIndexOf("\n\n", phraseIndex);
    const insertAt = paragraphBreakIndex === -1 ? 0 : paragraphBreakIndex + 2;
    const markers = insertions.get(insertAt) ?? [];
    markers.push(indexAnchorMarkup(anchor.id));
    insertions.set(insertAt, markers);
  }

  let output = normalizedMarkdown;
  const sortedInsertions = [...insertions.entries()].sort(([a], [b]) => b - a);

  for (const [insertAt, markers] of sortedInsertions) {
    output = `${output.slice(0, insertAt)}${markers.join("\n")}\n\n${output.slice(insertAt)}`;
  }

  return output;
}

function indexAnchorMarkup(id: string) {
  return `<div id="${id}" class="print-index-anchor" aria-hidden="true"></div>`;
}

function collectIndexTargets(entries: IndexEntry[]) {
  const targets = new Set<string>();

  for (const entry of entries) {
    for (const target of entry.targets ?? []) {
      targets.add(target);
    }

    for (const subentry of entry.subentries ?? []) {
      for (const target of subentry.targets) {
        targets.add(target);
      }
    }
  }

  return targets;
}

function sectionId(order: number) {
  return `chapter-${order + 1}`;
}

function tocPageNumber(order: number) {
  return tocPageNumbers[order] ?? "";
}

function partId(part: string) {
  return part
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");
}

function partTitle(part: string) {
  return part.replace(/^Part\s+[IVX]+\s*-\s*/, "").trim();
}

const printSections = [];
const seenParts = new Set<string>();

for (const entry of renderedSections) {
  const part = entry.section.data.part;

  if (part.startsWith("Part ") && !seenParts.has(part)) {
    seenParts.add(part);
    printSections.push({ type: "part", part, id: partId(part) });
  }

  printSections.push({ type: "section", ...entry });
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="author" content={book.author} />
    <meta name="description" content={`Print/PDF edition of ${book.title} by ${book.author}.`} />
    <title>{book.title} | PDF Edition</title>
  </head>
  <body>
    <section class="half-title-page" aria-label="Half title">
      <h1>{book.title}</h1>
    </section>

    <section class="title-page" aria-label="Title page">
      <div>
        <p class="title-eyebrow">OK is NOT enough</p>
        <h1>{book.title}</h1>
        <p class="title-subtitle">{book.subtitle}</p>
        <p class="title-author">{book.author}</p>
      </div>
    </section>

    <section class="copyright-page" aria-label="Copyright page">
      <p><strong>{book.title}</strong></p>
      <p>Copyright &copy; 2026 Tomas Svitorka and Kevin L. Michel.</p>
      <p>All rights reserved.</p>
      <p>
        No part of this publication may be reproduced, distributed, transmitted, stored in a retrieval system, or used in any form or by any means, electronic, mechanical, photocopying, recording, or otherwise, without prior written permission from the copyright owners, except as permitted by law.
      </p>
      <p>
        This book is intended for personal-development, coaching, and educational purposes. It does not replace professional medical, psychological, financial, legal, or therapeutic advice.
      </p>
      <p>Production Access live-draft PDF edition.</p>
      <p>Printed in the United States of America.</p>
    </section>

    <nav class="toc-page" aria-label="Table of contents">
      <h1>Contents</h1>
      <ol>
        {
          printSections.map((section) =>
            section.type === "part" ? (
              <li class="toc-part-row">
                <div class="toc-part">
                  <span>{section.part}</span>
                </div>
              </li>
            ) : (
              <li>
                <div class="toc-entry" data-target={`#${section.printId}`} data-page={tocPageNumber(section.section.data.order)}>
                  <span class="toc-chapter">{section.label}</span>
                  <span class="toc-title">{section.section.data.title}</span>
                </div>
              </li>
            )
          )
        }
      </ol>
    </nav>

    <main class="book-body">
      {
        printSections.map((section) =>
          section.type === "part" ? (
            <section class="part-opener" id={section.id}>
              <p class="chapter-kicker">{section.part}</p>
              <h1>{partTitle(section.part)}</h1>
            </section>
          ) : (
            <PrintBookChapter
              chapter={section.section}
              printId={section.printId}
              html={section.html}
              kickerLabel={section.label}
              showSubtitle={false}
            />
          )
        )
      }
    </main>

    <section class="about-author-page" aria-label="About the Author">
      <h1>About the Author</h1>
      <p>{aboutAuthor}</p>
    </section>

    <section class="index-page" aria-label="Index">
      <h1>Index</h1>
      <PrintIndex entries={indexEntries} />
    </section>
  </body>
</html>
