---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import FormatLinks from "../../../components/FormatLinks.astro";
import { getBooks } from "../../../lib/books";
import {
  chapterHref,
  getBookChapters,
  getChapterWordCount,
  groupChaptersByPart,
  readingTimeFromWords
} from "../../../lib/bookWorld";

const books = await getBooks();
const book = books.find((entry) => entry.id === "mental-toughness-dreams");

if (!book) {
  throw new Error("Mental Toughness catalogue record not found.");
}

const sections = await getBookChapters("mental-toughness-dreams");
const parts = groupChaptersByPart(sections);
const firstSection = sections[0];
const totalWords = sections.reduce((sum, section) => sum + getChapterWordCount(section), 0);
const chapterCount = sections.filter((section) => section.data.order > 0).length;

const pillars = [
  {
    name: "Purpose",
    line: "The guiding vector that keeps ambition pointed when motivation starts to flicker."
  },
  {
    name: "Persistence",
    line: "The elastic identity that bends under pressure, recovers, and returns to the work."
  },
  {
    name: "Precision Practice",
    line: "The upgrade loop: stretch, feedback, correction, repetition, and earned confidence."
  },
  {
    name: "Perspective",
    line: "The distance that lets the mind see pressure clearly instead of obeying it blindly."
  }
];

const applications = [
  "Sport and fitness under pressure",
  "Business and leadership decisions",
  "Creative work and music production",
  "Stress inoculation without burnout",
  "Teaching toughness to others"
];

function sectionLabel(order: number) {
  return order === 0 ? "Author's Note" : `Chapter ${order}`;
}

function partHeading(part: string) {
  return part.replace(/^Part\s+[IVX]+\s+-\s*/, "").replace(/^Opening\s+-\s*/, "").trim();
}
---

<BaseLayout
  title="Mental Toughness | Kevin L. Michel - The Library"
  description={book.data.description}
  bodyClass="theme-mental-toughness-dreams"
>
  <section class="book-world-hero mental-hero" aria-labelledby="mental-title">
    <div class="book-world-hero__copy">
      <p class="eyebrow">Mental Toughness</p>
      <h1 id="mental-title">The mind does not become strong by accident.</h1>
      <p class="book-world-hero__subtitle">{book.data.subtitle}</p>
      <p class="book-world-hero__lede">
        A practical manual for turning dreams into trained capacity: purpose, persistence,
        precision practice, perspective, and the inner sovereignty to keep moving when
        pressure arrives.
      </p>
      <div class="hero__actions">
        {firstSection && <a class="button button--primary" href={chapterHref(firstSection)}>Start reading</a>}
        <a class="button button--ghost" href="#section-map">Explore chapters</a>
        <a class="text-link" href="/books/">Return to Library</a>
      </div>
      <FormatLinks formats={book.data.formats} />
    </div>

    <aside class="book-world-cover mental-cover" aria-label="Mental Toughness cover">
      <img src={book.data.cover} alt="Mental Toughness cover by Kevin L. Michel" />
    </aside>
  </section>

  <section class="freedom-stats mental-stats" aria-label="Book statistics">
    <div>
      <strong>{chapterCount}</strong>
      <span>chapters</span>
    </div>
    <div>
      <strong>{parts.length}</strong>
      <span>movements</span>
    </div>
    <div>
      <strong>{readingTimeFromWords(totalWords)}</strong>
      <span>minute read</span>
    </div>
  </section>

  <section class="freedom-section mental-section mental-promise">
    <p class="eyebrow">The book promise</p>
    <h2>Dreams need more than vision. They need a trained nervous system.</h2>
    <p>
      Mental Toughness treats resilience as a buildable system: a way of thinking,
      practicing, recovering, and executing when talent is no longer enough and the
      old mood has already disappeared.
    </p>
  </section>

  <section class="freedom-section mental-section" aria-labelledby="equation-heading">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Toughness equation</p>
        <h2 id="equation-heading">Purpose times persistence, sharpened by practice and perspective</h2>
      </div>
    </div>
    <div class="outcome-grid mental-pillar-grid">
      {
        pillars.map((pillar) => (
          <article>
            <span>{pillar.name}</span>
            <p>{pillar.line}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="freedom-section mental-section" aria-labelledby="method-heading">
    <div class="section-heading">
      <div>
        <p class="eyebrow">The Michel Method</p>
        <h2 id="method-heading">Where toughness has to become real</h2>
      </div>
    </div>
    <div class="practice-grid mental-practice-grid">
      {
        applications.map((application, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{application}</h3>
            <p>
              A proving ground where pressure exposes the gap between intention and trained
              response, then gives the reader a way to close it.
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="freedom-section mental-section" id="section-map" aria-labelledby="section-map-heading">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Chapter map</p>
        <h2 id="section-map-heading">From raw talent to the infinite game</h2>
      </div>
    </div>

    <div class="part-map">
      {
        parts.map(({ part, chapters }) => (
          <section class="part-panel mental-part-panel" aria-labelledby={`part-${chapters[0].data.order}`}>
            <p class="part-panel__label">{part}</p>
            <h3 id={`part-${chapters[0].data.order}`}>{partHeading(part)}</h3>
            <div class="chapter-grid">
              {chapters.map((section) => (
                <a class="chapter-tile mental-chapter-tile" href={chapterHref(section)}>
                  <span>{sectionLabel(section.data.order)}</span>
                  <strong>{section.data.title}</strong>
                  <small>{section.data.summary}</small>
                </a>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </section>
</BaseLayout>
