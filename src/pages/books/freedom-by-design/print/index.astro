---
import { render } from "astro:content";
import PrintBookChapter from "../../../../components/PrintBookChapter.astro";
import { chapterSlug, getBookChapters } from "../../../../lib/bookWorld";

const book = {
  title: "Freedom by Design",
  subtitle: "Toltec Principles for Rewriting Your Beliefs and Reclaiming Your Life",
  author: "Kevin L. Michel"
};

const chapters = await getBookChapters("freedom-by-design");
const renderedChapters = await Promise.all(
  chapters.map(async (chapter) => {
    const { Content } = await render(chapter);
    return {
      chapter,
      Content,
      printId: chapter.data.order === 0 ? "introduction" : `chapter-${chapter.data.order}`,
      slug: chapterSlug(chapter)
    };
  })
);

function partId(part) {
  return part
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");
}

const printSections = [];
const seenParts = new Set();

for (const entry of renderedChapters) {
  const part = entry.chapter.data.part;

  if (part !== "Opening" && !seenParts.has(part)) {
    seenParts.add(part);
    printSections.push({ type: "part", part, id: partId(part) });
  }

  printSections.push({ type: "chapter", ...entry });
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="author" content={book.author} />
    <meta name="description" content={`Print/PDF edition of ${book.title} by ${book.author}.`} />
    <title>{book.title} | PDF Edition</title>
  </head>
  <body>
    <section class="title-page" aria-label="Title page">
      <div>
        <p class="title-eyebrow">A practical guide to inner freedom</p>
        <h1>{book.title}</h1>
        <p class="title-subtitle">{book.subtitle}</p>
        <p class="title-author">{book.author}</p>
      </div>
    </section>

    <section class="copyright-page" aria-label="Copyright page">
      <p><strong>{book.title}</strong></p>
      <p>Copyright © 2026 Kevin L. Michel.</p>
      <p>All rights reserved.</p>
      <p>
        No part of this publication may be reproduced, distributed, transmitted, stored in a retrieval system, or used in any form or by any means, electronic, mechanical, photocopying, recording, or otherwise, without prior written permission from the copyright owner, except as permitted by law.
      </p>
      <p>
        This book is provided for informational and educational purposes only. It does not constitute medical, legal, financial, psychological, therapeutic, spiritual, or other professional advice. Readers should consult qualified professionals for advice regarding their own circumstances.
      </p>
      <p>
        References to traditions, public figures, institutions, products, services, and events are used for commentary, criticism, education, and discussion. All trademarks and trade names are the property of their respective owners.
      </p>
      <p>Printed in the United States of America.</p>
    </section>

    <nav class="toc-page" aria-label="Table of contents">
      <h1>Contents</h1>
      <ol>
        {
          printSections.map((section) =>
            section.type === "part" ? (
              <li class="toc-part-row">
                <div class="toc-part">
                  <span>{section.part}</span>
                </div>
              </li>
            ) : (
              <li>
                <div class="toc-entry" data-target={`#${section.printId}`}>
                  <span class="toc-chapter">
                    {section.chapter.data.order === 0 ? "Intro" : `Chapter ${section.chapter.data.order}`}
                  </span>
                  <span class="toc-title">{section.chapter.data.title}</span>
                </div>
              </li>
            )
          )
        }
      </ol>
    </nav>

    <main class="book-body">
      {
        printSections.map((section) =>
          section.type === "part" ? (
            <section class="part-opener" id={section.id}>
              <p class="chapter-kicker">{section.part}</p>
              <h1>{section.part.replace(/^Part\s+[IVX]+:\s*/, "")}</h1>
            </section>
          ) : (
            <PrintBookChapter
              chapter={section.chapter}
              printId={section.printId}
              Content={section.Content}
            />
          )
        )
      }
    </main>
  </body>
</html>
