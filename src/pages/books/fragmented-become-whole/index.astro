---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import FormatLinks from "../../../components/FormatLinks.astro";
import { getBooks } from "../../../lib/books";
import {
  chapterHref,
  getBookChapters,
  getChapterWordCount,
  groupChaptersByPart,
  readingTimeFromWords
} from "../../../lib/bookWorld";

const books = await getBooks();
const book = books.find((entry) => entry.id === "fragmented-become-whole");

if (!book) {
  throw new Error("Fragmented book catalogue record not found.");
}

const chapters = await getBookChapters("fragmented-become-whole");
const parts = groupChaptersByPart(chapters);
const firstChapter = chapters[0];
const totalWords = chapters.reduce((sum, chapter) => sum + getChapterWordCount(chapter), 0);
const downloadFormat = book.data.formats.find(
  (format) => format.href && format.label.toLowerCase().includes("download")
);
const voices = [
  "The Self",
  "The Infinite",
  "The Alchemist",
  "The Scientist",
  "The Underground Man",
  "The Shadow"
];
const practices = [
  "Name the voices without exiling them",
  "Listen beneath the argument",
  "Meet the shadow without theatrics",
  "Let contradiction become conversation",
  "Return to the world with a steadier heart"
];

function sectionLabel(order: number) {
  if (order === 0) return "Prologue";
  if (order === 11) return "Epilogue";
  return `Chapter ${order}`;
}
---

<BaseLayout
  title="A Book for the Fragmented Who Seek to Become Whole | Kevin L. Michel - The Library"
  description={book.data.description}
  bodyClass="theme-fragmented-become-whole"
>
  <section class="book-world-hero fragmented-hero" aria-labelledby="fragmented-title">
    <div class="book-world-hero__copy">
      <p class="eyebrow">A Book for the Fragmented</p>
      <h1 id="fragmented-title">Gather the pieces without declaring war on yourself.</h1>
      <p class="book-world-hero__subtitle">
        A symbolic inner journey through fracture, shadow, alchemy, and return.
      </p>
      <p class="book-world-hero__lede">
        This is a book for the self that has become a room full of voices: the skeptic, the
        wounded child, the analyst, the mystic, the shadow, the one who still hopes. It does not
        ask you to silence them. It asks you to listen until a deeper wholeness can hold them all.
      </p>
      <div class="hero__actions">
        <a class="button button--primary" href={chapterHref(firstChapter)}>Start reading</a>
        {downloadFormat && <a class="button button--ghost" href={downloadFormat.href}>Download PDF</a>}
        <a class="button button--ghost" href="#chapter-map">Explore the journey</a>
        <a class="text-link" href="/books/">Return to Library</a>
      </div>
      <FormatLinks formats={book.data.formats} />
    </div>

    <aside class="book-world-cover fragmented-cover" aria-label="A Book for the Fragmented cover">
      <img src={book.data.cover} alt="A Book for the Fragmented Who Seek to Become Whole cover by Kevin L. Michel" />
    </aside>
  </section>

  <section class="freedom-stats fragmented-stats" aria-label="Book statistics">
    <div>
      <strong>{chapters.length}</strong>
      <span>sections</span>
    </div>
    <div>
      <strong>{parts.length}</strong>
      <span>movements</span>
    </div>
    <div>
      <strong>{readingTimeFromWords(totalWords)}</strong>
      <span>minute read</span>
    </div>
  </section>

  <section class="freedom-section fragmented-section fragmented-promise">
    <p class="eyebrow">The invitation</p>
    <h2>Wholeness is not the absence of contradiction.</h2>
    <p>
      The book moves like an inner theatre: voices arrive, resist, grieve, accuse, bless, and
      slowly learn to stand in the same room. The work is not to become seamless. The work is to
      become real enough that no part of you needs exile to survive.
    </p>
  </section>

  <section class="freedom-section fragmented-section" aria-labelledby="voices-heading">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Cast of voices</p>
        <h2 id="voices-heading">The inner council</h2>
      </div>
    </div>
    <div class="voice-grid">
      {voices.map((voice) => <span>{voice}</span>)}
    </div>
  </section>

  <section class="freedom-section fragmented-section" aria-labelledby="practice-heading">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Practice arc</p>
        <h2 id="practice-heading">How the journey asks to be read</h2>
      </div>
    </div>
    <div class="practice-grid">
      {
        practices.map((practice, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{practice}</h3>
            <p>
              A quiet discipline for the reader: not a worksheet, but a way of paying attention
              while the story works on the inner life.
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="freedom-section fragmented-section" id="chapter-map" aria-labelledby="chapter-map-heading">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Journey map</p>
        <h2 id="chapter-map-heading">From shattered mirror to living integration</h2>
      </div>
    </div>

    <div class="part-map">
      {
        parts.map(({ part, chapters: partChapters }) => (
          <section class="part-panel fragmented-part-panel" aria-labelledby={`part-${partChapters[0].data.order}`}>
            <p class="part-panel__label">{part}</p>
            <h3 id={`part-${partChapters[0].data.order}`}>{part.replace(/^Movement\s+[IVX]+\s+-\s*/, "")}</h3>
            <div class="chapter-grid">
              {partChapters.map((chapter) => (
                <a class="chapter-tile fragmented-chapter-tile" href={chapterHref(chapter)}>
                  <span>{sectionLabel(chapter.data.order)}</span>
                  <strong>{chapter.data.title}</strong>
                  <small>{chapter.data.summary}</small>
                </a>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </section>
</BaseLayout>
