<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="author" content={book.author} />
    <meta name="description" content={`Print/PDF edition of ${book.title} by ${book.author}.`} />
    <title>{book.title} | PDF Edition</title>
  </head>
  <body>
    <section class="half-title-page" aria-label="Half title">
      <h1>{book.title}</h1>
    </section>

    <section class="title-page" aria-label="Title page">
      <div>
        <p class="title-eyebrow">A breakthrough guide to possibility</p>
        <h1>{book.title}</h1>
        <p class="title-subtitle">{book.subtitle}</p>
        <p class="title-author">{book.author}</p>
      </div>
    </section>

    <section class="copyright-page" aria-label="Copyright page">
      <p><strong>{book.title}</strong></p>
      <p>Copyright &copy; 2026 Kevin L. Michel.</p>
      <p>All rights reserved.</p>
      <p>
        No part of this publication may be reproduced, distributed, transmitted, stored in a retrieval system, or used in any form or by any means, electronic, mechanical, photocopying, recording, or otherwise, without prior written permission from the copyright owner, except as permitted by law.
      </p>
      <p>
        This book is provided for informational, educational, and self-development purposes only. It does not constitute medical, legal, financial, psychological, therapeutic, spiritual, fitness, or other professional advice. Readers should consult qualified professionals for advice regarding their own circumstances.
      </p>
      <p>
        References to research, public figures, institutions, products, services, events, and traditions are used for commentary, criticism, education, and discussion. All trademarks and trade names are the property of their respective owners.
      </p>
      <p>Printed in the United States of America.</p>
    </section>

    <nav class="toc-page" aria-label="Table of contents">
      <h1>Contents</h1>
      <ol>
        {
          printSections.map((section) =>
            section.type === "part" ? (
              <li class="toc-part-row">
                <div class="toc-part">
                  <span>{section.part}</span>
                </div>
              </li>
            ) : (
              <li>
                <div class="toc-entry" data-target={`#${section.printId}`} data-page={tocPageNumber(section.section.data.order)}>
                  <span class="toc-chapter">{section.label}</span>
                  <span class="toc-title">{section.section.data.title}</span>
                </div>
              </li>
            )
          )
        }
      </ol>
    </nav>

    <main class="book-body">
      {
        printSections.map((section) =>
          section.type === "part" ? (
            <section class="part-opener" id={section.id}>
              <p class="chapter-kicker">{section.part}</p>
              <h1>{partTitle(section.part)}</h1>
            </section>
          ) : (
            <PrintBookChapter
              chapter={section.section}
              printId={section.printId}
              html={section.html}
              kickerLabel={section.label}
              startOnRecto={section.section.data.order === 0}
              showSubtitle={false}
            />
          )
        )
      }
    </main>

    <section class="about-author-page" aria-label="About the Author">
      <h1>About the Author</h1>
      <p>{aboutAuthor}</p>
    </section>

    <section class="index-page" aria-label="Index">
      <h1>Index</h1>
      <ul>
        {
          indexEntries.map((entry) => (
            <li class="index-entry">
              <div class="index-line">
                <span class="index-term">{entry.term}</span>
                {entry.targets && (
                  <span class="index-pages">
                    {entry.targets.map((target, index) => (
                      <>
                        {index > 0 && <span class="index-separator">, </span>}
                        <span class="index-page-ref" data-target={`#${target}`}></span>
                      </>
                    ))}
                  </span>
                )}
              </div>
              {entry.subentries && (
                <ul class="index-subentries">
                  {entry.subentries.map((subentry) => (
                    <li>
                      <span class="index-subterm">{subentry.term}</span>
                      <span class="index-pages">
                        {subentry.targets.map((target, index) => (
                          <>
                            {index > 0 && <span class="index-separator">, </span>}
                            <span class="index-page-ref" data-target={`#${target}`}></span>
                          </>
                        ))}
                      </span>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))
        }
      </ul>
    </section>
  </body>
</html>
