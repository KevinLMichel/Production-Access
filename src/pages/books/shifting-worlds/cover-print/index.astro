---
const title = "Shifting Worlds";
const author = "Kevin L. Michel";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={`Full-wrap KDP cover for ${title} by ${author}.`} />
    <title>{title} | Paperback Cover</title>
  </head>
  <body>
    <main class="cover-sheet" aria-label={`Full paperback cover for ${title}`}>
      <div class="cover-wrap-source" aria-hidden="true"></div>
      <section class="spine-repair" aria-label="Book spine">
        <span class="spine-title">SHIFTING WORLDS</span>
        <span class="spine-author">{author}</span>
      </section>
    </main>
  </body>
</html>
