---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import FormatLinks from "../../../components/FormatLinks.astro";
import { getBooks } from "../../../lib/books";
import {
  chapterHref,
  getBookChapters,
  getChapterWordCount,
  groupChaptersByPart,
  readingTimeFromWords
} from "../../../lib/bookWorld";

const books = await getBooks();
const book = books.find((entry) => entry.id === "will-to-fail");

if (!book) {
  throw new Error("The Will to Fail catalogue record not found.");
}

const sections = await getBookChapters("will-to-fail");
const parts = groupChaptersByPart(sections);
const firstSection = sections[0];
const totalWords = sections.reduce((sum, section) => sum + getChapterWordCount(section), 0);
const chapterCount = sections.filter((section) => section.data.order > 0).length;

const payoffs = [
  {
    name: "Comfort",
    line: "The soft cell: excuses, lowered expectations, and familiar pain dressed up as safety."
  },
  {
    name: "Identity",
    line: "The old role that feels coherent even when it keeps the life small."
  },
  {
    name: "Drama",
    line: "The stimulation of conflict when peace starts to feel suspicious."
  },
  {
    name: "Sympathy",
    line: "The strange reward of being rescued, pitied, or expected to do less."
  },
  {
    name: "Excuse",
    line: "The self-handicap that protects potential by never letting it fully stand trial."
  },
  {
    name: "Chaos",
    line: "The baseline that makes order feel foreign until crisis restores the old weather."
  }
];

const fieldMoves = [
  "Name the payoff before naming the excuse",
  "Separate shame from ownership",
  "Lower the morning friction",
  "Refuse the identity that needs defeat",
  "Choose the next forged action"
];

function sectionLabel(order: number) {
  return order === 0 ? "Prologue" : `Chapter ${order}`;
}

function partHeading(part: string) {
  return part.replace(/^Part\s+[IVX]+\s+[–-]\s*/, "").replace(/^Opening\s+-\s*/, "").trim();
}
---

<BaseLayout
  title="The Will to Fail | Kevin L. Michel - The Library"
  description={book.data.description}
  bodyClass="theme-will-to-fail"
>
  <section class="book-world-hero will-hero" aria-labelledby="will-title">
    <div class="book-world-hero__copy">
      <p class="eyebrow">The Will to Fail</p>
      <h1 id="will-title">The door is open. Why are you still holding the bars?</h1>
      <p class="book-world-hero__subtitle">{book.data.dek}</p>
      <p class="book-world-hero__lede">
        A confrontational field manual for the part of the self that keeps choosing delay,
        drama, excuses, and familiar defeat. Not comfort reading. Forge reading.
      </p>
      <div class="hero__actions">
        {firstSection && <a class="button button--primary" href={chapterHref(firstSection)}>Start reading</a>}
        <a class="button button--ghost" href="#section-map">Explore sections</a>
        <a class="text-link" href="/books/">Return to Library</a>
      </div>
      <FormatLinks formats={book.data.formats} />
    </div>

    <aside class="book-world-cover will-cover" aria-label="The Will to Fail cover">
      <img src={book.data.cover} alt="The Will to Fail cover by Kevin L. Michel" />
    </aside>
  </section>

  <section class="freedom-stats will-stats" aria-label="Book statistics">
    <div>
      <strong>{chapterCount}</strong>
      <span>chapters</span>
    </div>
    <div>
      <strong>{parts.length}</strong>
      <span>movements</span>
    </div>
    <div>
      <strong>{readingTimeFromWords(totalWords)}</strong>
      <span>minute read</span>
    </div>
  </section>

  <section class="freedom-section will-section will-promise">
    <p class="eyebrow">The book promise</p>
    <h2>This is a confession wrapped in a dare.</h2>
    <p>
      The Will to Fail names the hidden bargain beneath self-sabotage: the comfort, identity,
      sympathy, stimulation, and protection that can make defeat feel useful. Then it asks the
      harder question: what would you become if you stopped being loyal to the pattern?
    </p>
  </section>

  <section class="freedom-section will-section" aria-labelledby="payoff-heading">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Hidden payoffs</p>
        <h2 id="payoff-heading">Why failure can feel like shelter</h2>
      </div>
    </div>
    <div class="outcome-grid will-payoff-grid">
      {
        payoffs.map((payoff) => (
          <article>
            <span>{payoff.name}</span>
            <p>{payoff.line}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="freedom-section will-section" aria-labelledby="field-moves-heading">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Field moves</p>
        <h2 id="field-moves-heading">How the book turns the blade around</h2>
      </div>
    </div>
    <div class="practice-grid will-practice-grid">
      {
        fieldMoves.map((move, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{move}</h3>
            <p>
              A direct move against the old bargain: less soothing, more ownership, and one
              next action that proves the will is changing hands.
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="freedom-section will-section" id="section-map" aria-labelledby="section-map-heading">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Section map</p>
        <h2 id="section-map-heading">From the cell to the forge</h2>
      </div>
    </div>

    <div class="part-map">
      {
        parts.map(({ part, chapters }) => (
          <section class="part-panel will-part-panel" aria-labelledby={`part-${chapters[0].data.order}`}>
            <p class="part-panel__label">{part}</p>
            <h3 id={`part-${chapters[0].data.order}`}>{partHeading(part)}</h3>
            <div class="chapter-grid">
              {chapters.map((section) => (
                <a class="chapter-tile will-chapter-tile" href={chapterHref(section)}>
                  <span>{sectionLabel(section.data.order)}</span>
                  <strong>{section.data.title}</strong>
                  <small>{section.data.summary}</small>
                </a>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </section>
</BaseLayout>
