---
import BaseLayout from "../layouts/BaseLayout.astro";
import GlassPanel from "../components/GlassPanel.astro";
---

<BaseLayout title="About | Production Access" description="About the Production Access studio system.">
  <section class="page-intro">
    <p class="eyebrow">About the studio</p>
    <h1>A production system for many books</h1>
    <p>
      Production Access is the working front door for manuscript development, book-world
      builds, downloadable interiors, cover workflows, production updates, and future
      ghostwriting-ready publishing systems.
    </p>
  </section>

  <section class="split-showcase">
    <GlassPanel>
      <h2>Simple now</h2>
      <p>
        V1 is intentionally static: no database, no accounts, no CMS, and no hidden admin layer.
        The catalogue is stored in Markdown, deployed as a fast static site, and easy to adapt
        as the studio grows.
      </p>
    </GlassPanel>
    <GlassPanel>
      <h2>Built to scale</h2>
      <p>
        Each book can later point to its own full site, PDF, paperback, audiobook, source notes,
        intake workflow, production packet, or project page while this studio remains the
        central proof-of-capability layer.
      </p>
    </GlassPanel>
  </section>
</BaseLayout>
