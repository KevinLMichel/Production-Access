---
import BaseLayout from "../layouts/BaseLayout.astro";
import BookCard from "../components/BookCard.astro";
import FeaturedBook from "../components/FeaturedBook.astro";
import GlassPanel from "../components/GlassPanel.astro";
import { getAllTopics, getBooks, getBooksByShelf, getFeaturedBook } from "../lib/books";
import { siteMeta } from "../lib/siteMeta";

const books = await getBooks();
const featuredBook = await getFeaturedBook();
const featured = getBooksByShelf(books, "Featured").slice(0, 6);
const active = getBooksByShelf(books, "New & Active").slice(0, 6);
const fieldGuides = getBooksByShelf(books, "Field Guides").slice(0, 6);
const comingSoon = getBooksByShelf(books, "Coming Soon").slice(0, 8);
const topics = getAllTopics(books).slice(0, 18);
const readableCount = books.filter((book) => book.data.status === "available" || book.data.formats.some((format) => format.href)).length;
const downloadCount = books.filter((book) => book.data.formats.some((format) => format.href?.toLowerCase().endsWith(".pdf"))).length;
---

<BaseLayout title={siteMeta.displayTitle} description={siteMeta.description} bodyClass="home-page">
  <section class="hero">
    <div class="hero__copy">
      <p class="eyebrow">Book Access</p>
      <h1>Kevin L. Michel <span>The Library</span></h1>
      <p class="hero__lede">
        A future-facing catalogue for the collected works: field guides, philosophical manuals,
        parables, poems, strategy books, and living manuscripts.
      </p>
      <div class="hero__actions">
        <a class="button button--primary" href="/books/">Browse the books</a>
        <a class="button button--ghost" href="/author/">About Kevin</a>
      </div>
      <div class="hero-signal-strip" aria-label="Library experience highlights">
        <span>Read online</span>
        <span>Track progress locally</span>
        <span>Return by signal</span>
      </div>
    </div>

    <GlassPanel className="hero__stat-panel">
      <p class="eyebrow">Current archive</p>
      <strong>{books.length}</strong>
      <span>catalogued titles</span>
      <div class="hero-stat-grid" aria-label="Library availability">
        <div>
          <b>{readableCount}</b>
          <small>readable</small>
        </div>
        <div>
          <b>{downloadCount}</b>
          <small>PDFs</small>
        </div>
      </div>
      <div class="signal-bars" aria-hidden="true">
        <span></span><span></span><span></span><span></span>
      </div>
    </GlassPanel>
  </section>

  <section class="library-dashboard" data-library-dashboard aria-labelledby="dashboard-heading">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Reader OS</p>
        <h2 id="dashboard-heading">Your Library dashboard</h2>
      </div>
      <a class="text-link" href="/books/">Open full catalogue</a>
    </div>

    <div class="dashboard-grid">
      <GlassPanel className="dashboard-card dashboard-card--continue">
        <p class="eyebrow">Continue reading</p>
        <h3 data-dashboard-title>No active session yet</h3>
        <p data-dashboard-copy>Open any readable book and the Library will remember your place on this device.</p>
        <a class="button button--ghost" href="/books/" data-dashboard-link>Choose a book</a>
      </GlassPanel>

      <GlassPanel className="dashboard-card">
        <p class="eyebrow">Available now</p>
        <strong>{readableCount}</strong>
        <span>readable titles</span>
      </GlassPanel>

      <GlassPanel className="dashboard-card">
        <p class="eyebrow">Downloads</p>
        <strong>{downloadCount}</strong>
        <span>PDF interiors</span>
      </GlassPanel>

      <GlassPanel className="dashboard-card dashboard-card--signals">
        <p class="eyebrow">Recent signals</p>
        <div class="dashboard-signals" data-dashboard-signals>
          <span>clarity</span>
          <span>discipline</span>
          <span>agency</span>
        </div>
      </GlassPanel>
    </div>
  </section>

  <FeaturedBook book={featuredBook} />

  <section class="shelf-section" aria-labelledby="featured-heading">
    <div class="section-heading">
      <p class="eyebrow">Start here</p>
      <h2 id="featured-heading">Featured works</h2>
    </div>
    <div class="rail-shell" data-rail-shell>
      <div class="rail-controls" aria-label="Featured works carousel controls">
        <span class="rail-hint">Scroll, drag, or let it orbit</span>
        <div class="rail-buttons">
          <button type="button" data-rail-prev aria-controls="featured-rail" aria-label="Previous featured works">‹</button>
          <button type="button" data-rail-next aria-controls="featured-rail" aria-label="Next featured works">›</button>
        </div>
      </div>
      <div class="book-rail" id="featured-rail" aria-label="Featured works carousel">
        {featured.map((book) => <BookCard book={book} variant="shelf" />)}
      </div>
    </div>
  </section>

  <section class="shelf-section" aria-labelledby="active-heading">
    <div class="section-heading">
      <p class="eyebrow">In motion</p>
      <h2 id="active-heading">New and active</h2>
    </div>
    <div class="rail-shell" data-rail-shell>
      <div class="rail-controls" aria-label="New and active carousel controls">
        <span class="rail-hint">Pause, browse, continue</span>
        <div class="rail-buttons">
          <button type="button" data-rail-prev aria-controls="active-rail" aria-label="Previous new and active books">‹</button>
          <button type="button" data-rail-next aria-controls="active-rail" aria-label="Next new and active books">›</button>
        </div>
      </div>
      <div class="book-rail" id="active-rail" aria-label="New and active carousel">
        {active.map((book) => <BookCard book={book} variant="shelf" />)}
      </div>
    </div>
  </section>

  <section class="split-showcase">
    <GlassPanel>
      <p class="eyebrow">Browse by signal</p>
      <h2>Topics across the library</h2>
      <div class="topic-cloud">
        {topics.map((topic) => <a href={`/books/?topic=${encodeURIComponent(topic)}`}>{topic}</a>)}
      </div>
    </GlassPanel>
    <GlassPanel>
      <p class="eyebrow">Coming shelf</p>
      <h2>Future catalogue records</h2>
      <ul class="compact-list">
        {comingSoon.map((book) => <li><a href={`/books/${book.id}/`}>{book.data.title}</a></li>)}
      </ul>
    </GlassPanel>
  </section>

  <section class="shelf-section" aria-labelledby="field-guide-heading">
    <div class="section-heading">
      <p class="eyebrow">Practical shelf</p>
      <h2 id="field-guide-heading">Field guides and strategy books</h2>
    </div>
    <div class="rail-shell" data-rail-shell>
      <div class="rail-controls" aria-label="Field guide carousel controls">
        <span class="rail-hint">Manual controls stay active</span>
        <div class="rail-buttons">
          <button type="button" data-rail-prev aria-controls="field-guide-rail" aria-label="Previous field guides and strategy books">‹</button>
          <button type="button" data-rail-next aria-controls="field-guide-rail" aria-label="Next field guides and strategy books">›</button>
        </div>
      </div>
      <div class="book-rail" id="field-guide-rail" aria-label="Field guides and strategy books carousel">
        {fieldGuides.map((book) => <BookCard book={book} variant="shelf" />)}
      </div>
    </div>
  </section>
</BaseLayout>
