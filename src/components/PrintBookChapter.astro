---
const { chapter, printId, Content } = Astro.props;
const isIntroduction = chapter.data.order === 0;
---

<article class:list={["print-chapter", isIntroduction && "print-chapter--introduction"]} id={printId}>
  <header class="chapter-opener">
    <p class="chapter-kicker">{isIntroduction ? "Introduction" : `Chapter ${chapter.data.order}`}</p>
    <h1>{chapter.data.title}</h1>
    {chapter.data.subtitle && <p class="chapter-subtitle">{chapter.data.subtitle}</p>}
  </header>
  <div class="chapter-body">
    <Content />
  </div>
</article>
