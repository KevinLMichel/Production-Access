---
const { chapter, printId, Content, html } = Astro.props;
const { kickerLabel } = Astro.props;
const { startOnRecto = false } = Astro.props;
const { showSubtitle = true } = Astro.props;
const isIntroduction = chapter.data.order === 0;
const defaultKicker = isIntroduction ? "Introduction" : `Chapter ${chapter.data.order}`;
---

<article class:list={["print-chapter", isIntroduction && "print-chapter--introduction", startOnRecto && "print-chapter--recto"]} id={printId}>
  <header class="chapter-opener">
    <p class="chapter-kicker">{kickerLabel ?? defaultKicker}</p>
    <h1>{chapter.data.title}</h1>
    {showSubtitle && chapter.data.subtitle && <p class="chapter-subtitle">{chapter.data.subtitle}</p>}
  </header>
  <div class="chapter-body">
    {html ? <Fragment set:html={html} /> : <Content />}
  </div>
</article>
